{
  "name": "siri-tax",
  "productName": "Siri Tax",
  "version": "1.0.4",
  "description": "",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electronmon . --watch src pages styles",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "build:win64": "build --win --x64",
    "build:win": "npm run build:win32 && npm run build:win64"
  },
  "build": {
    "appId": "com.secuinfo.siritax",
    "productName": "Siri Tax",
    "icon": "src/assets/icons/Siri_Tax_Icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "secuwell",
        "repo": "Siri_Tax"
      }
    ],
    "compression": "store",
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-log/**",
      "renderer/**",
      "styles/**"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "pages/**/*",
      "renderer/**/*",
      "styles/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        "zip",
        "nsis"
      ],
      "icon": "src/assets/icons/Siri_Tax_Icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Siri Tax"
    },
    "artifactName": "Siri_Tax_Installer.exe"
  },
  "keywords": [],
  "author": {
    "name": "choijaemin",
    "email": "cjm@sentry.co.kr"
  },
  "license": "ISC",
  "dependencies": {
    "@sentry/electron": "^6.7.0",
    "axios": "^1.9.0",  
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "form-data": "^4.0.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "electron": "36.2.0",
    "electron-builder": "^26.0.12",
    "electron-log": "^5.4.1",
    "electron-reload": "^2.0.0-alpha.1",
    "electronmon": "^2.0.3"
  }
}
